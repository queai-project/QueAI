# =========================================================================
# QueAI Kernel — Variables de entorno
# =========================================================================
# Copia este archivo a .env y ajusta lo que necesites:
#   cp .env.example .env

# --- Versión del kernel (informativa, se muestra en la UI) ---
VERSION="1.0.2"

# --- Directorio donde el kernel descubre plugins ---
PLUGINS_DIR="./plugins"

# --- Puertos del host ---
# Puerto HTTP por el que se sirve la UI del kernel.
# Usamos 8473 (puerto poco común) en vez del clásico 8080 para minimizar
# colisiones con Jenkins/Tomcat/proxies de desarrollo. El instalador
# detecta si está ocupado y propone uno libre automáticamente.
QUEAI_PORT=8473
# Puerto del dashboard interno de Traefik (protegido por basic-auth)
QUEAI_TRAEFIK_DASHBOARD_PORT=9473

# --- Django: seguridad ---
# Cambia a True solo para desarrollo local
DEBUG=False
# Genera un valor único con:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# Si lo dejas vacío y DEBUG=False, el kernel se niega a arrancar.
SECRET_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8473

# --- API REST (bearer token único) ---
# Genera uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(40))"
# Si lo dejas vacío y DEBUG=True, el kernel autogenera uno por sesión.
QUEAI_API_TOKEN=

# --- Admin inicial (auto-creado en primer arranque) ---
# Si QUEAI_ADMIN_USER está vacío, debes crear el admin manualmente con:
#   docker compose run --rm django-kernel python manage.py createsuperuser
QUEAI_ADMIN_USER=admin
QUEAI_ADMIN_PASSWORD=changeme
QUEAI_ADMIN_EMAIL=admin@queai.local
# Pon true para rotar la password del admin existente en el próximo arranque
QUEAI_ADMIN_ROTATE_PASSWORD=false

# --- Auth básica del dashboard de Traefik ---
# Genera el hash con:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin <password>
# Pega el resultado tal cual (incluyendo el usuario). Escapa cualquier $ como $$.
# Default: admin / queai (cámbialo antes de exponer el dashboard).
QUEAI_TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$Qd1nXrFf$$NyrJxQp9oVUEy0Lp9SQID/

# --- Logging ---
LOG_LEVEL=INFO

# --- Modo dev (runserver con auto-reload en lugar de gunicorn) ---
QUEAI_DEV=false

# --- gunicorn ---
QUEAI_GUNICORN_WORKERS=3
QUEAI_GUNICORN_THREADS=2
QUEAI_GUNICORN_TIMEOUT=120
